ARCHIVE_BUCKET=xyz-tradfi-archive
ARCHIVE_S3_ENDPOINT=http://minio:9000
ARCHIVE_S3_ACCESS_KEY=minioadmin
ARCHIVE_S3_SECRET_KEY=minioadmin
ARCHIVE_S3_REGION=us-east-1
ARCHIVE_S3_FORCE_PATH_STYLE=true

ARCHIVER_STATE_DIR=/var/lib/xyz-tradfi-archiver
ARCHIVER_RUN_ID=

HYPERLIQUID_BASE_URL=https://api.hyperliquid.xyz
HYPERLIQUID_WEBSOCKET_URL=wss://api.hyperliquid.xyz/ws
HYPERLIQUID_DEX=xyz
HYPERLIQUID_SYMBOL_ALLOWLIST=

ARCHIVE_TIMEFRAMES=15m,4h,1d
ARCHIVE_CANDLE_LOOKBACK_BARS=240
ARCHIVE_FUNDING_LOOKBACK_DAYS=7

RECORDER_FSYNC_EVERY_EVENTS=1
RECORDER_SEGMENT_MAX_BYTES=134217728
RECORDER_SEGMENT_MAX_AGE_SECONDS=300
RECORDER_IDLE_SLEEP_SECONDS=1

POLL_PERP_DEXS_SECONDS=3600
POLL_META_ASSET_CTXS_SECONDS=30
POLL_ALL_MIDS_SECONDS=5
POLL_L2_SNAPSHOT_SECONDS=10
POLL_FUNDING_HISTORY_SECONDS=900
POLL_CANDLES_SECONDS=60

WRITER_LOOP_SLEEP_SECONDS=5
VALIDATOR_LOOP_SLEEP_SECONDS=60
